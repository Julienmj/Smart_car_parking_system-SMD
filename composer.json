{
    "name": "smart-parking-system",
    "description": "Modern car parking management system with real-time slot tracking",
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    },
    "require-dev": {
        "heroku/heroku-buildpack-php": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "SmartParking\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php -v"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
